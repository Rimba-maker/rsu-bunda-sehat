---
import { mcuPackages, mcuSpecials } from '../../data/mcu';
---
<section class="section" id="mcu">
  <div class="container">
    <h2 class="section-title reveal">Paket Medical Check-Up</h2>
    <p class="section-sub reveal">Deteksi dini, pencegahan terbaik. Pilih paket sesuai kebutuhan.</p>

    <!-- Main packages -->
    <div class="pkg-grid">
      {mcuPackages.map((p) => (
        <div class:list={['pkg-card card-hover reveal', p.popular && 'popular']}>
          {p.popular && <span class="popular-badge">⭐ Paling Populer</span>}
          <div class="icon">{p.icon}</div>
          <div class="name">{p.name}</div>
          <div class="price">{p.price}</div>
          <div class="target">{p.target}</div>
          <ul class="items">
            {p.items.map((item) => <li>{item}</li>)}
          </ul>
          <a href="#booking" class="btn-primary" style="display:block; text-align:center; margin-top:auto;">
            Pesan Paket
          </a>
        </div>
      ))}
    </div>

    <!-- Special packages -->
    <div class="special-grid">
      {mcuSpecials.map((s) => (
        <div class="special-card reveal">
          <span class="s-icon">{s.icon}</span>
          <div>
            <div class="s-name">{s.name}</div>
            <div class="s-price">{s.price}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .pkg-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 28px;
  }
  .pkg-card {
    background: var(--color-canvas);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-md);
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    position: relative;
  }
  .pkg-card.popular {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 2px rgba(255,56,92,.12);
  }
  .popular-badge {
    position: absolute; top: -13px; left: 50%; transform: translateX(-50%);
    background: var(--color-primary); color: #fff;
    font-size: 11px; font-weight: 600;
    padding: 4px 16px;
    border-radius: 9999px;
    white-space: nowrap;
  }
  .icon   { font-size: 28px; margin-bottom: 12px; }
  .name   { font-size: 18px; font-weight: 700; color: var(--color-ink); margin-bottom: 4px; }
  .price  { font-size: 22px; font-weight: 700; color: var(--color-primary); margin-bottom: 4px; }
  .target {
    font-size: 13px; color: var(--color-muted); font-style: italic;
    margin-bottom: 16px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--color-hairline-soft);
  }
  .items  { list-style: none; display: flex; flex-direction: column; gap: 6px; margin-bottom: 20px; flex: 1; }
  .items li {
    font-size: 14px; color: var(--color-body-text);
    padding-left: 20px;
    position: relative;
  }
  .items li::before {
    content: '✓';
    color: var(--color-primary);
    font-weight: 700;
    position: absolute; left: 0;
  }

  .special-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }
  .special-card {
    background: var(--color-canvas);
    border: 1px solid var(--color-hairline-soft);
    border-radius: var(--radius-md);
    padding: 18px 20px;
    display: flex; gap: 14px; align-items: flex-start;
  }
  .s-icon  { font-size: 24px; flex-shrink: 0; }
  .s-name  { font-size: 14px; font-weight: 600; color: var(--color-ink); margin-bottom: 3px; }
  .s-price { font-size: 13px; color: var(--color-muted); }

  @media (max-width: 768px) {
    .pkg-grid    { grid-template-columns: 1fr; }
    .special-grid{ grid-template-columns: 1fr; }
  }
</style>
