<style>
  .footer {
    background: var(--color-canvas);
    border-top: 1px solid var(--color-hairline-soft);
    padding-top: 48px;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 40px;
    margin-bottom: 40px;
  }
  .brand-row { display: flex; align-items: center; gap: 10px; margin-bottom: 12px; }
  .logo-mark {
    width: 36px; height: 36px;
    background: var(--color-primary);
    border-radius: var(--radius-sm);
    display: flex; align-items: center; justify-content: center;
    color: #fff; font-weight: 700; font-size: 13px;
    flex-shrink: 0;
  }
  .logo-name { font-size: 14px; font-weight: 700; }
  .logo-sub  { font-size: 11px; color: var(--color-muted); }
  .tagline { font-size: 14px; color: var(--color-muted); line-height: 1.6; margin-bottom: 14px; max-width: 220px; }
  .accreds { display: flex; flex-wrap: wrap; gap: 6px; }
  .accred {
    background: var(--color-surface-soft);
    border: 1px solid var(--color-hairline-soft);
    border-radius: var(--radius-xs);
    padding: 3px 8px;
    font-size: 11px; font-weight: 600; color: var(--color-muted);
  }
  .col-title { font-size: 13px; font-weight: 600; color: var(--color-ink); margin-bottom: 14px; }
  .foot-links { display: flex; flex-direction: column; gap: 8px; }
  .foot-links a { font-size: 14px; color: var(--color-muted); transition: color .15s; }
  .foot-links a:hover { color: var(--color-ink); }
  .address { font-size: 13px; color: var(--color-muted); margin-top: 14px; line-height: 1.6; }

  .legal-band {
    border-top: 1px solid var(--color-hairline-soft);
    padding: 18px 0;
    display: flex; align-items: center; justify-content: space-between;
    flex-wrap: wrap; gap: 10px;
  }
  .legal-text { font-size: 12px; color: var(--color-muted-soft); }
  .legal-text a { color: inherit; text-decoration: underline; }
  .socials { display: flex; gap: 10px; }
  .social {
    width: 32px; height: 32px;
    background: var(--color-surface-soft);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 14px;
    transition: background .15s;
  }
  .social:hover { background: var(--color-surface-mid); }

  @media (max-width: 768px) {
    .footer-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 480px) {
    .footer-grid { grid-template-columns: 1fr; }
  }
</style>
