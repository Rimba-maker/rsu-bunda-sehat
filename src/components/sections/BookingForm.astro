---
const specializations = [
  'Penyakit Dalam',
  'Kandungan & Kebidanan',
  'Anak',
  'Bedah Umum',
  'Jantung & Pembuluh Darah',
  'Saraf',
  'Mata',
  'THT',
  'Kulit & Kelamin',
  'Ortopedi',
  'Urologi',
  'Paru',
] as const;
---
<section class="booking-section" id="booking">
  <div class="container">
    <div class="grid">
      <!-- Left: copy -->
      <div class="copy">
        <h2>Buat Janji Temu<br />Online</h2>
        <p>
          Pilih dokter, tanggal, dan jam yang sesuai. Kami akan mengkonfirmasi
          dalam 1 jam kerja — tanpa perlu datang ke loket.
        </p>
        <div class="alts">
          <div class="alt">
            <span class="alt-icon">💬</span>
            <div>
              <strong>WhatsApp Langsung</strong>
              <span>0812-3456-7890 — respons cepat</span>
            </div>
          </div>
          <div class="alt">
            <span class="alt-icon">📞</span>
            <div>
              <strong>Telepon Customer Care</strong>
              <span>(021) 555-1999 — Senin–Sabtu 07.00–20.00</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: form -->
      <div class="form-card">
        <div class="form-title">Form Janji Temu</div>
        <form id="bookingForm">
          <div class="form-grid">
            <div class="field">
              <label>Nama Lengkap</label>
              <input type="text" placeholder="Nama sesuai KTP" required />
            </div>
            <div class="field">
              <label>Tanggal Lahir</label>
              <input type="date" required />
            </div>
            <div class="field">
              <label>Nomor WhatsApp</label>
              <input type="tel" placeholder="08xx-xxxx-xxxx" required />
            </div>
            <div class="field">
              <label>Tanggal Preferensi</label>
              <input type="date" required />
            </div>
            <div class="field full">
              <label>Spesialisasi</label>
              <select required>
                <option value="">Pilih spesialisasi...</option>
                {specializations.map((s) => <option value={s}>{s}</option>)}
              </select>
            </div>
            <div class="field full">
              <label>Nama Dokter <span class="opt">(Opsional)</span></label>
              <input type="text" placeholder="Biarkan kosong jika belum ada preferensi" />
            </div>
          </div>
          <button type="submit" class="submit-btn" id="submitBtn">
            Buat Janji Temu →
          </button>
          <p class="note">Konfirmasi dikirim via WhatsApp dalam 1 jam kerja</p>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  .booking-section {
    background: linear-gradient(135deg, #2a1a1f 0%, #180a0d 100%);
    padding: 64px 0;
  }
  .grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  /* Copy */
  .copy h2 { font-size: 32px; font-weight: 700; color: #fff; line-height: 1.25; margin-bottom: 14px; }
  .copy p  { font-size: 15px; color: rgba(255,255,255,.65); line-height: 1.7; margin-bottom: 28px; }
  .alts    { display: flex; flex-direction: column; gap: 14px; }
  .alt     { display: flex; align-items: flex-start; gap: 12px; color: rgba(255,255,255,.7); font-size: 14px; }
  .alt-icon { font-size: 20px; flex-shrink: 0; margin-top: 1px; }
  .alt strong { display: block; color: #fff; font-weight: 600; margin-bottom: 2px; }

  /* Form card */
  .form-card {
    background: var(--color-canvas);
    border-radius: var(--radius-lg);
    padding: 32px;
  }
  .form-title { font-size: 18px; font-weight: 700; color: var(--color-ink); margin-bottom: 22px; }
  .form-grid  { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 16px; }

  .field { display: flex; flex-direction: column; gap: 5px; }
  .field.full { grid-column: span 2; }
  label  { font-size: 12px; font-weight: 600; color: var(--color-ink); }
  .opt   { font-weight: 400; color: var(--color-muted); }

  input, select {
    height: 44px;
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-sm);
    padding: 0 12px;
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--color-ink);
    background: var(--color-canvas);
    outline: none;
    transition: border-color .15s;
    width: 100%;
  }
  input:focus, select:focus { border-color: var(--color-ink); border-width: 2px; }

  .submit-btn {
    width: 100%;
    height: 48px;
    background: var(--color-primary);
    color: #fff;
    border: none;
    border-radius: var(--radius-sm);
    font-family: var(--font-sans);
    font-size: 15px;
    font-weight: 500;
    cursor: pointer;
    transition: background .15s;
    margin-bottom: 8px;
  }
  .submit-btn:hover { background: var(--color-primary-hover); }
  .note { font-size: 12px; color: var(--color-muted); text-align: center; }

  @media (max-width: 768px) {
    .grid      { grid-template-columns: 1fr; gap: 40px; }
    .form-grid { grid-template-columns: 1fr; }
    .field.full{ grid-column: span 1; }
  }
</style>

<script>
  document.getElementById('bookingForm')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const btn = document.getElementById('submitBtn') as HTMLButtonElement;
    btn.textContent = '✅ Janji terkirim — kami akan konfirmasi segera';
    btn.style.background = '#22c55e';
    btn.disabled = true;
  });
</script>
