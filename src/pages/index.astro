---
import BaseLayout from '../layouts/BaseLayout.astro';
import EmergencyBanner from '../components/EmergencyBanner.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/sections/Hero.astro';
import QuickAccess from '../components/sections/QuickAccess.astro';
import Services from '../components/sections/Services.astro';
import Doctors from '../components/sections/Doctors.astro';
import Facilities from '../components/sections/Facilities.astro';
import MCU from '../components/sections/MCU.astro';
import Insurance from '../components/sections/Insurance.astro';
import HealthTips from '../components/sections/HealthTips.astro';
import PatientStories from '../components/sections/PatientStories.astro';
import Location from '../components/sections/Location.astro';
import BookingForm from '../components/sections/BookingForm.astro';
import '../styles/global.css';
---
<BaseLayout
  title="RSU Bunda Sehat — Rumah Sakit Umum Tipe B Jakarta Timur, 15 Spesialisasi"
  description="Rumah sakit umum tipe B di Jakarta Timur. 15 spesialisasi, IGD 24/7, 80+ dokter spesialis. Akreditasi Paripurna KARS. BPJS & 20+ asuransi."
>
  <EmergencyBanner />
  <Navbar />
  <main>
    <Hero />
    <QuickAccess />
    <Services />
    <Doctors />
    <Facilities />
    <MCU />
    <Insurance />
    <HealthTips />
    <PatientStories />
    <Location />
    <BookingForm />
  </main>
  <Footer />
</BaseLayout>
