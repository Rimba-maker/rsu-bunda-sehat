---
const stories = [
  {
    quote: 'Anak saya operasi appendicitis di RSU Bunda Sehat. Tim dokter dan perawat sabar menjelaskan setiap langkah, anak saya cepat pulih. Pelayanan benar-benar caring.',
    name: 'Ibu Lina',
    label: 'Ibu pasien anak, Jakarta Timur',
    avatar: 'https://images.unsplash.com/photo-1508214751196-bcfd4ca60f91?w=80&q=80',
  },
  {
    quote: 'Sebagai pasien BPJS, antrian dan layanan cukup efisien. Dokter penyakit dalam saya komunikatif, tidak terburu-buru, dan penjelasannya sangat jelas.',
    name: 'Pak Bambang',
    label: 'Pensiunan, pasien rawat jalan',
    avatar: 'https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?w=80&q=80',
  },
  {
    quote: 'Melahirkan anak pertama di sini. Fasilitas NICU sangat lengkap saat bayi butuh perawatan ekstra. Nurse 24/7 supportive dan selalu memperbarui kondisi bayi.',
    name: 'Bu Sari',
    label: 'Ibu baru, pasien Birth Center',
    avatar: 'https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=80&q=80',
  },
  {
    quote: 'MCU tahunan kami sekeluarga sudah 3 tahun di sini. Hasil cepat keluar, dokter menjelaskan dengan sangat baik, dan follow-up tindakan lanjutannya jelas.',
    name: 'Keluarga Wijaya',
    label: 'Pasien MCU tahunan sejak 2021',
    avatar: 'https://images.unsplash.com/photo-1544005313-94ddf0286df2?w=80&q=80',
  },
] as const;
---
<section class="section" id="cerita">
  <div class="container">
    <h2 class="section-title reveal">Cerita Dari Pasien Kami</h2>
    <p class="section-sub reveal">Pengalaman nyata keluarga yang mempercayakan kesehatan mereka kepada kami.</p>

    <div class="grid">
      {stories.map((s) => (
        <div class="card reveal">
          <div class="stars">★★★★★</div>
          <p class="quote">"{s.quote}"</p>
          <div class="author">
            <div
              class="avatar"
              style={`background-image: url('${s.avatar}')`}
              role="img"
              aria-label={`Foto ${s.name}`}
            ></div>
            <div>
              <div class="name">{s.name}</div>
              <div class="label">{s.label}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }
  .card {
    background: var(--color-surface-soft);
    border: 1px solid var(--color-hairline-soft);
    border-radius: var(--radius-md);
    padding: 24px 26px;
  }
  .stars { color: var(--color-ink); font-size: 13px; margin-bottom: 12px; letter-spacing: 1px; }
  .quote { font-size: 15px; color: var(--color-body-text); line-height: 1.7; margin-bottom: 18px; font-style: italic; }
  .author { display: flex; align-items: center; gap: 12px; }
  .avatar {
    width: 40px; height: 40px;
    border-radius: 50%;
    background-size: cover; background-position: center;
    background-color: var(--color-surface-mid);
    flex-shrink: 0;
  }
  .name  { font-size: 14px; font-weight: 600; color: var(--color-ink); }
  .label { font-size: 12px; color: var(--color-muted); }

  @media (max-width: 768px) { .grid { grid-template-columns: 1fr; } }
</style>
