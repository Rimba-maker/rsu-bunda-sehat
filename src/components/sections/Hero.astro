---
---
<section class="hero">
  <div class="hero-bg"></div>
  <div class="hero-content">
    <h1>Kesehatan Keluarga Anda,<br />Prioritas Kami.</h1>
    <p>
      Rumah sakit umum tipe B dengan 15 spesialisasi, 250 tempat tidur,<br />
      dan layanan 24/7 di Jakarta Timur. Akreditasi Paripurna KARS 2024.
    </p>

    <!-- Pill Search Bar (Airbnb pattern) -->
    <div class="search-pill">
      <div class="seg">
        <div class="seg-label">Spesialisasi</div>
        <div class="seg-val">Cari spesialisasi...</div>
      </div>
      <div class="seg">
        <div class="seg-label">Tanggal</div>
        <div class="seg-val">Pilih tanggal</div>
      </div>
      <div class="seg no-border">
        <div class="seg-label">Nama Dokter</div>
        <div class="seg-val">Opsional</div>
      </div>
      <button class="search-orb" aria-label="Cari dokter">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
      </button>
    </div>

    <!-- Trust Badges (Airbnb guest-favorite pattern) -->
    <div class="trust-row">
      <span class="trust-badge">✅ KARS Paripurna 2024</span>
      <span class="trust-badge">✅ Terdaftar BPJS</span>
      <span class="trust-badge">✅ 20+ Asuransi Partner</span>
      <span class="trust-badge">✅ ISO 9001:2015</span>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 520px;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: #1a1a1a;
  }
  .hero-bg {
    position: absolute; inset: 0;
    background-image: url('https://images.unsplash.com/photo-1504813184591-01572f98c85f?w=1920&q=80');
    background-size: cover;
    background-position: center 30%;
    opacity: .28;
  }
  .hero-content {
    position: relative; z-index: 1;
    width: 100%; max-width: 780px;
    margin: 0 auto;
    padding: 88px 32px;
    text-align: center;
  }
  h1 {
    font-size: clamp(28px, 4vw, 46px);
    font-weight: 700;
    color: #fff;
    line-height: 1.18;
    letter-spacing: -.5px;
    margin-bottom: 14px;
  }
  p {
    font-size: 16px;
    color: rgba(255,255,255,.8);
    line-height: 1.7;
    margin-bottom: 36px;
  }

  /* Search pill */
  .search-pill {
    background: #fff;
    border-radius: 9999px;
    padding: 6px 6px 6px 24px;
    display: flex;
    align-items: center;
    max-width: 650px;
    margin: 0 auto 28px;
    box-shadow: 0 6px 32px rgba(0,0,0,.28), 0 0 0 1px rgba(255,255,255,.06);
  }
  .seg {
    flex: 1;
    padding: 6px 16px 6px 0;
    border-right: 1px solid var(--color-hairline);
    text-align: left;
  }
  .seg.no-border { border-right: none; padding-left: 16px; padding-right: 0; }
  .seg-label { font-size: 11px; font-weight: 600; color: var(--color-ink); margin-bottom: 2px; }
  .seg-val   { font-size: 13px; color: var(--color-muted-soft); }
  .search-orb {
    background: var(--color-primary);
    color: #fff;
    border: none;
    border-radius: 50%;
    width: 50px; height: 50px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    cursor: pointer;
    transition: background .15s, transform .12s;
  }
  .search-orb:hover { background: var(--color-primary-hover); transform: scale(1.06); }

  /* Trust badges */
  .trust-row { display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; }
  .trust-badge {
    background: rgba(255,255,255,.13);
    border: 1px solid rgba(255,255,255,.22);
    color: #fff;
    padding: 6px 14px;
    border-radius: 9999px;
    font-size: 12px;
    font-weight: 500;
    backdrop-filter: blur(4px);
  }

  @media (max-width: 768px) {
    .hero-content { padding: 64px 16px; }
    .search-pill {
      flex-wrap: wrap;
      border-radius: var(--radius-md);
      padding: 16px;
      gap: 0;
    }
    .seg {
      border-right: none;
      border-bottom: 1px solid var(--color-hairline);
      padding: 10px 0;
      width: 100%;
    }
    .seg.no-border { border-bottom: none; }
    .search-orb { width: 100%; border-radius: var(--radius-sm); height: 44px; margin-top: 10px; }
    p br { display: none; }
  }
</style>
